# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.2

# Runtime
LOG_LEVEL=info
DB_PATH=./data/workspace-buddy.db
RING_BUFFER_SIZE=300
DEFAULT_SUMMARY_WINDOW=50
MAX_CONTEXT_MESSAGES=80

# Rate limits
CHAT_REQUESTS_PER_HOUR=20
HEAVY_COMMANDS_PER_10_MIN=3

# Bot behavior
BOT_LANGUAGE=ru
ALLOW_AMBIENT_MODE=false
